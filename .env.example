# Copy this file to .env and fill in your real values.
# NEVER commit a real .env file. It must stay in .gitignore.

# Required for optional Azure OpenAI explanation helpers.
# Without these, both degrade gracefully to a clear NOT_CONFIGURED message
# rather than crashing -- the rest of the system (rules engine, ML
# prediction, follow-up comparison, etc.) works fully without them.

# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-api-key-here
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional. If unset, falls back to AZURE_OPENAI_DEPLOYMENT.
# AZURE_OPENAI_MODEL=gpt-4o

# Comma-separated list of frontend origins allowed to call the FastAPI
# backend's API (app/main.py, app/config.py::_default_cors_origins()).
# If unset, defaults to local-development-only origins
# (http://localhost:8501, http://127.0.0.1:8501) and NEVER to a
# wildcard. Set this explicitly before any real deployment -- see
# infrastructure/azure_deploy.md.
# CORS_ALLOWED_ORIGINS=http://localhost:8501,https://your-streamlit-app-url

# Optional. Controls the provisional Manchester-style research ruleset.
# Defaults to ON (enabled), so the engine assigns PROVISIONAL, unvalidated,
# clinician-review-required Manchester categories by default. These are NOT the
# official Manchester Triage System and NOT clinically approved -- see
# RULESET_PROVENANCE.md. Set to "off" to fully gate the engine (no category
# assigned to any case). This is a safety-relevant setting. Formal
# PATIENT_DATA_MODE deployments must set PROVISIONAL_MTS_MODE=off unless a
# separate clinically approved ruleset replaces this research ruleset.
# PROVISIONAL_MTS_MODE=on

# Local credentialed MIMIC-IV-ED research profile.
# Use this on your approved local machine to view your own credentialed,
# de-identified MIMIC-IV-ED rows in the app without claiming the full hospital
# production security posture. The backend must bind to loopback only. Leave
# these commented unless you are on that approved local credentialed machine.
# LOCAL_CREDENTIALED_RESEARCH=true
# BACKEND_BIND_HOST=127.0.0.1
# FRONTEND_BIND_HOST=127.0.0.1
# FASTAPI_BASE_URL=http://127.0.0.1:8000
# LOCAL_RESEARCH_ROLE=triage_nurse
# PSEUDONYM_SECRET=generate-a-long-random-local-secret
# LOCAL_CREDENTIALED_OUTPUT_DIR=C:\path\outside\repo\ai-triage-local-output
# ACCESS_AUDIT_DIR=C:\path\outside\repo\ai-triage-local-output\audit
# Cloud LLM egress remains disabled in this profile unless BOTH the technical
# opt-in and governance approval of provider terms are set.
# ALLOW_CLOUD_LLM_IN_LOCAL_RESEARCH=true
# APPROVED_CLOUD_LLM_DATA_PROCESSING=true

# Point this at the extracted MIMIC-IV-ED `ed` directory containing:
# edstays.csv.gz, triage.csv.gz, vitalsign.csv.gz, diagnosis.csv.gz,
# medrecon.csv.gz, and pyxis.csv.gz. Do not point it at the zip file or the
# dataset root folder.
# MIMIC_FULL_ED_DIR=C:\Users\YOUR_USER\Downloads\mimic-iv-ed-2.2\ed

# Optional for predictions. Cases can be listed without this; assessments will
# report model unavailable until it points at a compatible full-MIMIC joblib.
# MIMIC_FULL_MODEL_PATH=C:\path\outside\repo\mimic_full_acuity_selected.joblib
# Optional for local research, REQUIRED in PATIENT_DATA_MODE before the backend
# will load a model artefact.
# MIMIC_FULL_MODEL_SHA256=<sha256-of-mimic_full_acuity_selected.joblib>

# Optional for aggregate performance/model-card display.
# MIMIC_FULL_MODEL_REPORT_DIR=C:\path\outside\repo\full_mimic_outputs
# Back-compatible fallback: MIMIC_FULL_REPORT_DIR or MIMIC_FULL_OUTPUT_DIR.

# Azure supervisor demo profile.
# Use only for a synthetic/no-real-patient-data Azure walkthrough where a
# supervisor needs to switch simulated roles in the sidebar. This is NOT real
# authentication and must not be combined with PATIENT_DATA_MODE,
# LOCAL_CREDENTIALED_RESEARCH, TRUSTED_AUTH_PROXY, AUTH_REQUIRED, or real MIMIC
# data. Azure deployments do not automatically inherit your local .env; set
# these as explicit App Service / Container App environment variables only for
# the demo instance.
# AZURE_SUPERVISOR_DEMO_MODE=true
# ALLOW_DEMO_ROLE_SWITCHER=true
# AUTH_PROVIDER=demo
# PATIENT_DATA_MODE=false
# REAL_PATIENT_DATA=false
# In this profile the app uses packaged synthetic MIMIC-shaped supervisor-demo
# cases by default. Do not configure MIMIC_FULL_ED_DIR for a boss/public demo.
# Only a governed non-public demo may opt into real full MIMIC:
# ALLOW_FULL_MIMIC_IN_AZURE_DEMO=true
# REAL_MIMIC_DEMO_ACKNOWLEDGED=true
# MIMIC_FULL_ED_DIR=C:\path\to\mimic-iv-ed-2.2\ed

# Patient-data deployment wiring (not needed for local credentialed research).
# These require `pip install -r requirements-azure.txt` and real Azure resources.
# PATIENT_DATA_MODE=true
# AUTH_REQUIRED=true
# AUTH_PROVIDER=azure
# TRUSTED_AUTH_PROXY=true
# SECRETS_PROVIDER=keyvault
# KEY_VAULT_URL=https://your-key-vault.vault.azure.net/
# Do NOT set plain env PSEUDONYM_SECRET in PATIENT_DATA_MODE when
# SECRETS_PROVIDER=keyvault. Store PSEUDONYM_SECRET in Key Vault; the app refuses
# the env var in that profile unless an explicit dev-test override is set.
# MIMIC_FULL_MODEL_PATH=/mnt/secure-models/mimic_full_acuity_selected.joblib
# MIMIC_FULL_MODEL_SHA256=<required-sha256-of-model-artefact>
# AUDIT_SINK=durable
# AZURE_AUDIT_TABLE_NAME=triageaudit
# Option A: use a connection string stored securely by the deployment platform.
# AZURE_AUDIT_TABLE_CONNECTION_STRING=...
# Option B: use managed identity with a table endpoint.
# AZURE_AUDIT_TABLE_ENDPOINT=https://youraccount.table.core.windows.net/
